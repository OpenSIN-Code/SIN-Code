{
  "mcpServers": {
    "websearch": {
      "transport": "stdio",
      "command": "sin-websearch",
      "args": ["serve"]
    },
    "browser": {
      "transport": "http",
      "url": "http://localhost:8931/mcp"
    },
    "scheduler": {
      "disabled": true
    },
    "my-custom-server": {
      "transport": "stdio",
      "command": "my-mcp-binary",
      "args": ["--flag"],
      "env": { "API_KEY": "${MY_API_KEY}" }
    }
  }
}
