{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "identifier": "dev.sinator.desktop",
  "productName": "SIN-Code Desktop",
  "version": "1.0.0",
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm --filter @sinator/web dev",
    "beforeBuildCommand": "cd ../.. && pnpm --filter @sinator/web build",
    "devPath": "http://localhost:3000",
    "distDir": "../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "SIN-Code Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "label": "main",
        "theme": "default",
        "hiddenTitle": false,
        "titleBarStyle": "visible",
        "zoomHotkeysEnabled": true,
        "devtools": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menu": {
        "items": [
          { "id": "show", "text": "Show SIN-Code" },
          { "id": "quit", "text": "Quit" }
        ]
      }
    },
    "security": {
      "csp": "default-src 'self' data: blob: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2024 OpenSIN-Code",
    "category": "DeveloperTool",
    "shortDescription": "SIN-Code Desktop GUI — unified agent engineering stack",
    "longDescription": "SIN-Code Desktop provides a native desktop interface for the SIN-Code agent engineering stack, including TUI, security tools, code analysis, and more.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "appStore": {
        "teamId": null
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHeaderIcon": "icons/icon.ico",
        "language": "English"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "appImage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["webkit2gtk-4.1", "libayatana-appindicator3-1", "librsvg2-2"]
      },
      "rpm": {
        "depends": ["webkit2gtk-4.1", "libayatana-appindicator3", "librsvg2"]
      }
    }
  },
  "plugins": {
    "store": {
      "saveOnExit": true,
      "autoSave": 5000
    },
    "updater": {
      "active": false,
      "endpoints": ["https://github.com/OpenSIN-Code/SIN-Code-Bundle/releases/latest/download/latest.json"],
      "dialog": true,
      "pubkey": ""
    }
  }
}